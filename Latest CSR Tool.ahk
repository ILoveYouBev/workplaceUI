IsAnyKeyPressed() {
    ; VK codes for mouse buttons and keyboard keys range roughly 1-254
    Loop, 254
    {
        vk := Format("VK{:X}", A_Index)
        ; Check physical state ("P") - whether the key is physically down
        if GetKeyState(vk, "P")
            return true
    }
    return false
}


