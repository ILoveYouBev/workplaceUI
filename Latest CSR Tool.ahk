	if (Elapsed > 1000) {
		return
	}
	ImageSearch,BatchX,BatchY,SB_BNX1, SB_BNY1,SB_BNX2, SB_BNY2,*10 Batch Number.PNG
	If !(ErrorLevel) {
		X:=BatchX+SB_BNOffSetX
		Y:=BatchY+SB_BNOffSetY
